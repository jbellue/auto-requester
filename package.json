{
    "name": "auto-request-extension",
    "version": "0.2",
    "description": "Browser extension to automatically send HTTP requests (e.g. to prevent session expiration)",
    "scripts": {
        "build": "tsc --noEmit && node scripts/build.cjs",
        "watch": "node scripts/build.cjs --watch",
        "dev": "node scripts/build.cjs --watch",
        "clean": "rimraf dist",
        "typecheck": "tsc --noEmit",
        "typecheck:watch": "tsc --noEmit --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "build:xpi": "web-ext build --source-dir dist --artifacts-dir web-ext-artifacts --overwrite-dest",
        "pipeline:watch": "node scripts/watch-pipeline.cjs",
        "source:zip": "node scripts/source-zip.cjs"
    },
    "devDependencies": {
        "@types/chrome": "^0.1.38",
        "@types/webextension-polyfill": "^0.12.5",
        "@vitest/coverage-v8": "^4.1.0",
        "esbuild": "^0.27.4",
        "jsdom": "^29.0.0",
        "rimraf": "^6.1.3",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0",
        "web-ext": "^8.0.0"
    },
    "dependencies": {
        "webextension-polyfill": "^0.12.0"
    }
}
